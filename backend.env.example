# Example backend runtime configuration for Docker Compose.
# Copy to backend.env and update values before deployment.

# --- JWT ---
JWT_SECRET=change-me-super-secret
JWT_ACCESS_DURATION_MS=900000
JWT_REFRESH_DURATION_MS=604800000

# --- Database ---
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/pmb_prod
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_DATASOURCE_USERNAME=pmb
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# --- MFA ---
MFA_OTP_DURATION_MINUTES=5
MFA_OTP_MAX_ATTEMPTS=5

# --- Frontend URL used to build invitation links in emails ---
APP_FRONTEND_BASE_URL=http://localhost:5173

# --- Mail ---
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@example.com
SPRING_MAIL_PASSWORD=your-app-password
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_REQUIRED=true

# --- GitHub OAuth ---
GITHUB_OAUTH_CLIENT_ID=change-me
GITHUB_OAUTH_CLIENT_SECRET=change-me
