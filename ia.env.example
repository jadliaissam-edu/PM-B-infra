# Example IA runtime configuration for Docker Compose.
# Copy to ia.env and update values before deployment.

# --- LLM / OpenRouter ---
OPENROUTER_API_KEY=change-me

# --- GitHub (optional, avoid rate limit) ---
GITHUB_TOKEN=

# --- GitHub PAT encryption (required for private repo storage) ---
ENCRYPTION_KEY=change-me-base64-fernet-key

# --- Backend Spring Boot accessible from IA ---
BACKEND_BASE_URL=
